<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textView_main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="129dp"
        android:text="@string/title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/songButton_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="22dp"
        android:onClick="goToSongList_1"
        android:text="@string/song_button_1"
        app:layout_constraintBaseline_toBaselineOf="@+id/songButton_2"
        app:layout_constraintEnd_toStartOf="@+id/songButton_2"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/songButton_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="84dp"
        android:layout_marginEnd="19dp"
        android:onClick="goToSongList_2"
        android:text="@string/song_button_2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/songButton_1"
        app:layout_constraintTop_toBottomOf="@+id/textView_main" />

</androidx.constraintlayout.widget.ConstraintLayout>